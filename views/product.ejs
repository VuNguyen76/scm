<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, noarchive">
  <title>Thông tin sản phẩm - Saigoncomm</title>
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>
  <main class="page">
    <div class="topbar" aria-hidden="true"></div>

    <section class="section product-summary">
      <h1>Thông tin tem lưu hành</h1>
      <dl class="details">
        <div><dt>Ngày phát hành tem:</dt><dd><%= label.issuedDate %></dd></div>
        <div><dt>Số series tem:</dt><dd><%= label.serialNumber %></dd></div>
        <div><dt>Đơn vị phát hành:</dt><dd><%= label.organizationName %></dd></div>
        <div><dt>Số lượt quét QR:</dt><dd><%= label.scanCount %></dd></div>
      </dl>

    </section>

    <section class="section description">
      <h2>THÔNG TIN SẢN PHẨM</h2>
      <hr>
      <h3><%= label.productName %></h3>
      <dl class="details">
        <div><dt>Tên sản phẩm:</dt><dd><%= label.productName %></dd></div>
        <div><dt>Tính năng chính:</dt><dd><%= label.productFeature %></dd></div>
        <div><dt>Dự án - phân khu:</dt><dd><%= label.projectArea %></dd></div>
        <div><dt>Ngày giao hàng:</dt><dd><%= label.deliveryDate %></dd></div>
        <div><dt>Ngày hoàn thành T&amp;C:</dt><dd><%= label.tcCompletionDate %></dd></div>
        <div><dt>Ngày bắt đầu bảo hành:</dt><dd><%= label.activationDate %></dd></div>
        <div><dt>Thời hạn bảo hành:</dt><dd><%= label.warrantyMonths %></dd></div>
        <div><dt>Ngày kết thúc bảo hành:</dt><dd><%= label.warrantyEndDate %></dd></div>
        <div><dt>Số giấy phép lưu hành:</dt><dd><%= label.circulationLicenseNo %></dd></div>
        <div><dt>Ngày cấp giấy phép lưu hành:</dt><dd><%= label.circulationLicenseDate %></dd></div>
        <div><dt>Số chứng nhận xuất xứ (C/O):</dt><dd><%= label.coReference %></dd></div>
        <div><dt>Số chứng nhận chất lượng (C/Q):</dt><dd><%= label.cqReference %></dd></div>
      </dl>

      <% if (label.productImages?.length) { %>
        <h3>HÌNH ẢNH VÀ TÀI LIỆU SẢN PHẨM</h3>
        <div class="product-gallery">
          <% label.productImages.forEach((image) => { %>
            <img src="<%= image.url %>" alt="<%= image.alt %>" loading="lazy">
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="section issuer">
      <h2>ĐƠN VỊ PHÁT HÀNH TEM</h2>
      <hr>
      <h3><%= label.issuer.name %></h3>
      <% if (label.issuer.address) { %>
        <p><span>Địa chỉ:</span> <%= label.issuer.address %></p>
      <% } %>
      <% if (label.issuer.phone) { %>
        <p><span>Số điện thoại:</span> <a href="tel:<%= label.issuer.phone %>"><%= label.issuer.phone %></a></p>
      <% } %>
      <% if (label.issuer.email) { %>
        <p><span>Email:</span> <a href="mailto:<%= label.issuer.email %>"><%= label.issuer.email %></a></p>
      <% } %>
      <% if (label.issuer.website) { %>
        <p><span>Website:</span> <a href="<%= label.issuer.website %>" rel="noopener"><%= label.issuer.website %></a></p>
      <% } %>
    </section>

    <p class="notice">Thông tin được cung cấp từ hệ thống quản lý tem lưu hành của Saigoncomm.</p>
  </main>
</body>
</html>
